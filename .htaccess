# Enable URL rewriting for pretty article URLs
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route /article/slug to article.php?slug=slug
  RewriteRule ^article/([^/]+)/?$ /article.php?slug=$1 [L,QSA]

  # Fallback: serve existing files normally
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]
</IfModule>

# Security headers (optional if host supports mod_headers)
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

# Disable directory listing
Options -Indexes
DirectoryIndex index.php

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^article/([^/]+)/?$ article.php?slug=$1 [L,QSA]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
